{
  "name": "liangyi",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsx watch src/server/index.ts",
    "dev:all": "concurrently -k -n web,api \"npm:dev\" \"npm:server\"",
    "db:setup": "tsx src/server/setup.ts",
    "db:reseed": "tsx src/server/reseed.ts",
    "build": "tsc -b && vite build && npm run build:api",
    "build:api": "esbuild src/server/handler.ts --bundle --platform=node --format=esm --packages=external --outfile=\"api/[...path].js\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "@imgly/background-removal": "^1.7.0",
    "@neondatabase/serverless": "^0.10.4",
    "@phosphor-icons/react": "^2.1.7",
    "@vercel/blob": "^2.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "framer-motion": "^11.11.0",
    "gsap": "^3.12.5",
    "hanzi-writer": "^3.7.3",
    "jsonwebtoken": "^9.0.2",
    "lenis": "^1.1.13",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "react-use-measure": "^2.1.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.9"
  }
}
